function hide_legend(){
    document.getElementById('legend').style.display = 'none';
    document.getElementById('legend-return').style.display = 'block';
}
function show_legend(){
    document.getElementById('legend').style.display = 'block';
    document.getElementById('legend-return').style.display = 'none';
}
function change_dataset(selected){
   console.log('selected',selected)
   dsets = ['erenv1v3','erenv3v5','hmpv1v3','hmpv3v5','metaphlan','dewhirst','mapping']
   var got_one_active = false
   for(n in active){
     if(active[n]){
       got_one_active = true
     }
   }
   if(got_one_active){
       for(n in dsets){
         if(active[dsets[n]]){
           document.getElementById(dsets[n]+'-div').style.display = 'none'
           document.getElementById(dsets[n]+'-btn').style.background = '#D0F0C0'
           document.getElementById(dsets[n]+'-btn').style.color = 'black'
         }
       }
       
       document.getElementById(selected+'-div').style.display = 'block'
       document.getElementById(selected+'-btn').style.background = 'olivedrab'
       document.getElementById(selected+'-btn').style.color = 'white'
   }else{
      //alert('allblank')
   }
}
function initialize(lv){
  console.log('in itit buttons')
  //console.log('active',active)
  // should de in order: erenv1v3:0,erenv3v5:0,hmpv1v3:0,hmpv3v5:0,metaphlan:0,dewhirst:0
  var got_one_active = false
  for(ds in active){
    //console.log(ds,active[ds])
    if(active[ds]){
       //show graph, then exit
        got_one_active = true
        first_active_div = ds+'-div'
        first_active_btn = ds+'-btn'
        document.getElementById(first_active_div).style.display = 'block'
        document.getElementById(first_active_btn).style.background = 'olivedrab'
        document.getElementById(first_active_btn).style.color = 'white'
        //change_dataset(ds)
    }else{
      
    }
  }
  
  //console.log('active',active)
  for(ds in active){
      if(active[ds] == 1){
          change_dataset(ds)
          break
      }
  }
  if(!got_one_active){
      document.getElementById('nodata-div').style.display = 'block'
  }
  //console.log('legend_visibility',lv)
  if(lv === 'show'){
    document.getElementById('legend').style.display = 'block';
    document.getElementById('legend-return').style.display = 'none';
  }else{
    document.getElementById('legend').style.display = 'none';
    document.getElementById('legend-return').style.display = 'block';
  }
}
initialize(legend_visibility)
