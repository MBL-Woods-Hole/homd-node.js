</div>
<div  class="grid-container"  >
<div id='plot-buttons'>
  <center>
    Available Datasets:<br>
    <% if(mapping_data.length){ %>
        &nbsp;<span id='mapping-btn' class='pill pill-teagreen-lg' onclick="change_dataset('mapping')">HMP Mapping</span>
    <% }else{ %>
        &nbsp;<span id='mapping-btn' class='pill pill-grey-lg'><small>ND:</small>Mapping</span>
    <% } %>
    <% if(erenv1v3_data.length){ %>
        &nbsp;<span id='erenv1v3-btn' class='pill pill-teagreen-lg' onclick="change_dataset('erenv1v3')">Eren V1-V3</span>
    <% }else{ %>
        &nbsp;<span id='erenv1v3-btn' class='pill pill-grey-lg'><small>ND:</small>Erenv1v3</span>
    <% } %>
