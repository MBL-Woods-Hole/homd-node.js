<%- include('../../partials/header_html'); %>



<body>
    <div id='wrapper'>
    <%- include('../../partials/header_img'); %>
    <%- include('../../partials/navbar'); %>
    
   
    <div class='page-content'>
    <% taxidfullname = 'HMT-'+("0000" + otid).slice(-4); %>
     <% if(rank == 'klass' || rank == 'Klass'){  %>
        <% rank_show = 'Class' %>
    <% }else{ %> 
       <% rank_show = rank.charAt(0).toUpperCase() + rank.slice(1) %>
    <% } %>
    
    <p class='title h3'>
      <b><%= rank_show %>:</b> 
      <span class='brown'>
      <% if(rank=='species') { %>
         <em><%= tax_name %></em>
      <% }else{ %>
         <%= tax_name %>
      <% } %>
      </span>
      <% if(otid != 0){ %>
       <small>(<%= taxidfullname %>)</small>
      <% } %>
    </p>
    
    <a class='download_browser_text_excel'  href='/download/download/abundance' >Download Options</a>   
    <div id='taxon-page-div'>
    <center>Full Lineage: <%- lineage %></center>
        
        <% if(children_lst.length == 0){ %>
             <br>
        <% }else{ %>
           
           <br><strong>Lower rank member(s): 
           <% if(children_lst.length <= 6){ %>
               <% for(n in children_lst){ %>
                 <span >[<%- children_lst[n] %>]</span>
               <% } %>
             
           <% }else{ %>
               <span id='toggle_ranks'><a href='#' onclick='toggle_lower_ranks()'>show[+]</a></span>
        
               <div id='lower-rank-items-div' style='display:none'>
                 <% cols = 5 %>
                 <table id='child-table'><tr>
                 <% for(n in children_lst){ %>
                   <% if(n % cols == 0){  %><!-- // modulus/modulo-->
                     </tr><tr>
                   <% } %>
                   <td>[<%- children_lst[n] %>]</td>
                 <% } %>
                 </tr></table>
               </div>
          <% } %>  <!-- End of if(children_lst.length <5 -->
  
        <% } %>
        
        
        <% if(['phylum','klass','order'].indexOf(rank) != -1){ %>
          <br>Genera:
          <select class='dropdown-homd' onchange="location = this.value;">
          <option value="" disabled selected>Select a genus</option>
          <% for(n in genera){ %>
              <option value='/taxa/ecology?rank=genus&name=<%= genera[n].taxon %>&page=<%= page %>'><%= genera[n].taxon %></option>
          <% } %>
          </select>
        <% } %>
        
        </strong>
        
    </div>  <!-- end taxon-page-div -->

<center>
<div class='links'>
     LINKS: <a href='/taxa/ecology_home'>Ecology Home</a>
     <% if(otid != 0){ %>
        <span>
          |&nbsp;<%= taxidfullname %>: [<a href='body_sites?otid=<%= otid %>'>Body Sites Data</a>]
          &nbsp;[<a href='tax_description?otid=<%= otid %>'>Taxon Description</a>]
        </span>
     <% } %>
     |&nbsp;Life Page: <a href='/taxa/life?rank=<%= rank %>&name=<%= tax_name %>'><%- tax_name %></a>
</div>
</center> 

<div id="legend" class="legend">
  <%- include('./ecology_lollipop_legend'); %>
</div>
<div id="legend-return" class='pill pill-brown'>
