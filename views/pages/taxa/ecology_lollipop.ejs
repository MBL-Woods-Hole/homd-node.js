<style>
.grid-container {
  display: flex;
  flex-direction: column;
}
.grid-container > div {
  border:1px solid grey;
  padding:10px 10px 10px 10px;
  
}
.legend{
   width:300px;
   font-size:12px;
   position:fixed;
   background:lightyellow;
   border:1px solid grey;
   padding:2px;
   left:20px;
   display:block;
   opacity:90%;
}
#legend-return{
    position:fixed;
    left:10px;
    font-size:12px;
    display:none;
    color: white;
}
.legend_item{
   border:1px solid black;
}
.abundance-table {
   border-collapse:collapse;
   
}
.abundance-table td,th{
   font-size:small;
   border:1px solid black;
   padding:1px;
   
  }
.plot-title{
   background:lightblue;
   padding:5px 3px;
   border:1px solid grey;
   font-size:x-large;
   
}
.pill a{
   color:white
}
.note{
  font-size:11px;
  padding:5px;
  background:ivory;
  border:1px solid tan;
  width:50%;
}
.font-size-xsm{
   font-size:0.7em;
}

#erenv1v3-div{
  display: none;
}
/* 
#erenv1v3-btn{
  background:purple;
  color:white;
}
 */
#mapping-div{
  display: none;
}
#erenv3v5-div{
  display: none;
}
#hmpv1v3-div{
  display: none;
}
#hmpv3v5-div{
  display: none;
}
#metaphlan-div{
  display: none;
}
#dewhirst-div{
  display: none;
}
#nodata-div{
  display: none;
}
.nonote{
    color:lightgrey;
}
</style>
<% mapping_data = JSON.parse(mapping) %>
<% dewhirst_data = JSON.parse(dewhirst) %>
<% erenv1v3_data = JSON.parse(erenv1v3) %>
<% erenv3v5_data = JSON.parse(erenv3v5) %>
