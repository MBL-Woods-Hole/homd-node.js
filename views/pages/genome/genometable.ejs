<script type="text/javascript" src="/js/menu.js"></script>
<script type="text/javascript" src="/js/genomes.js"></script>
<script>
    mainmenu()  // function in public/js/menu.js
    
    
    var letter = '<%- fltr.letter %>'
    var gid = '<%- filtergid %>'
    var filter_on = '<%- filter_on %>'
    var jb_path = '<%- cfg.JBROWSE_URL %>'
    var no_ncbi_annotation = '<%- no_ncbi_annot %>'
    
    console.log('JBPATH',jb_path)
    if(letter){
      document.getElementById(letter).style.color = 'red'
      document.getElementById(letter).style.fontSize = 'medium'
      document.getElementById(letter).style.textDecoration = 'underline'
    }
    if(filter_on === 'on'){
       document.getElementById('reset').style.color = 'black'
       document.getElementById('reset').style.background = 'orange'
       document.getElementById('reset').style.cursor = 'pointer'
       document.getElementById('reset').style.display = 'block'
       document.getElementById("reset").disabled = false;
    }
    //scrollto
    table = $('gnom-table')
    tableContainer = $('#genome-box')
    //otid = '325'
    if(gid){
        row = $('#'+gid.split('.')[0])  // MUST remove the '.' for id
        // scroll 2 more rows == 41 x2 ==164
        extra = 60
        if(row.length) {
           //console.log(row.offset().top);
           ///console.log(tableContainer.height()/2);
           tableContainer.scrollTop(row.offset().top - (tableContainer.height()/2) - extra)
        }
    }

//console.log('gid',gid)
document.onreadystatechange = function() {
        // just three els to loader: this(js);css;html
        if (document.readyState !== "complete") {
            document.querySelector(
                //'#genome-box').style.visibility = "hidden";
                '#genome-box').style.display = "none";
            document.querySelector(
                "#loader").style.visibility = "visible";
        } else {
            document.querySelector(
                "#loader").style.display = "none";
            document.querySelector(
                //'#genome-box').style.visibility = "visible";
                '#genome-box').style.display = "block";
        }
};
function openAdvancedForm() {
    var form = document.getElementById("myAdvancedForm") //.style.display// = "block";
    $(form).fadeIn();
}

function closeAdvancedForm() {
    document.getElementById("myAdvancedForm").style.display = "none";
}

///////////////////////////
    const overlay = document.getElementById('popupOverlay');
    //const title = document.getElementById('popupTitle');
    const pubody = document.getElementById('popupBody');

    // Open popup and populate with row data
    function openPopup(gid, otid, gc, phage) {
        //console.log('eco',ecology)
        var taxidfullname = 'HMT-'+("0000" + otid).slice(-4);
        //gc2 = (parseFloat(gc)/100).toFixed(2)
        pubody.innerHTML = "<div class='dropdown-content'>"
        pubody.innerHTML += `<span class='dd-head'>${gid}</span>`
        pubody.innerHTML += `<li><a class='pill pill-colorkit1' href='genome_description?gid=${gid}&otid=${otid}'>Genome Description</a></li>`
        pubody.innerHTML += `<li><a class='pill pill-colorkit2' href='#' onclick="open_jbrowse('${gid}','genome_table','${gc}')">Genome Viewer`
                
        pubody.innerHTML += `</a></li>`
        pubody.innerHTML += `<li><a class='pill pill-colorkit3 icon-link' href='conserved_protein_tree?gid=${gid}' target='_blank'>Genome Tree`
                  
        pubody.innerHTML += `</a></li>`
                
        pubody.innerHTML += `<li><a class='pill pill-colorkit4' href='/taxa/tax_description?gid=${gid}&otid=${otid}'>Taxon Info: ${taxidfullname}</a></li>`
        pubody.innerHTML += `<li><a class='pill pill-colorkit5' href='/taxa/tax_hierarchy?otid=${otid}'>Taxon Tree: ${taxidfullname}</a></li>`
                
        pubody.innerHTML += `<li><a class='pill pill-colorkit6' href='<%= cfg.BLAST_URL_BASE %>/genome_blast_single_prokka/?gid=${gid}' target="_self">BLAST</a></li>` 
        if(phage == 'yes' ){
            pubody.innerHTML += `<li><a class='pill pill-colorkit7' href='/phage/phage?gid=${gid}' target="_self">Phage</a></li>`
        }else{
            pubody.innerHTML += `<li><span class='pill pill-grayed' style='display:flex;text-align:center;margin:10px 0;font-size:15px;' title='Phage Not Available'>Phage (not available)</span></li>`
        }
        pubody.innerHTML += `<hr><span class='bold'><strong>Annotations</strong></span>`
        pubody.innerHTML += `<a class='pill pill-colorkit8' href='explorer?gid=${gid}&anno=prokka'>PROKKA</a>`
        if(no_ncbi_annotation.indexOf(gid) == -1 ){
            pubody.innerHTML += `<li><a class='pill pill-colorkit9' href='explorer?gid=${gid}&anno=ncbi'>NCBI</a></li>`
        }else{
            pubody.innerHTML += `<li><span class='pill pill-grayed' style='display:flex;text-align:center;margin:10px 0;font-size:15px;' title='NCBI Annotation Not Available' >NCBI (not available)</span></li>`
        }
            pubody.innerHTML += `<a class='pill pill-colorkit10' href='explorer?gid=${gid}&anno=bakta'>BAKTA</a>`
            pubody.innerHTML += `</div>`
      
      //title.innerText = `Details for ${genus} ${species}`;
      //pubody.innerText = `ID: ${otid}\nLength: ${glength}`;
      overlay.style.display = 'inline-block';
    }

    // Close popup only when clicking the overlay container background
    function closePopup(event) {
      if (event.target === overlay) {
        overlay.style.display = 'none';
      }
    }
</script>

