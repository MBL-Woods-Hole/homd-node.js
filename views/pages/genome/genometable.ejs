<style>

/* Fix the tax table header */
thead th { position: sticky; top: 0; }


#genome-box{
   display:none;
   height:700px;
   width:100%;
   overflow:auto;
   padding:10px 10px 20px 10px;
   border:1px solid gray;
   margin-top:5px;
}
#gnom-table {
  padding:5px;
  width: 100%; /* The table needs a defined width to trigger the overflow correctly */
  table-layout: fixed; /* Ensures columns respect the set widths */
}
#gnom-table th{
  color:white;
  background: var(--table-header-bg);
  padding:5px;
  font-size:13px;
  text-align: center;
  z-index: 1;
  
}
#gnom-table td{
  padding:3px 2px;
  
  font-size:small;
  font-weight:bold;
  color: #303030;
 
  
}
.ellipsis{
  /* max-width: 200px;   */       /* Defines the truncation boundary */
  white-space: nowrap;      /* Keeps the text on a single line */
  overflow: hidden;         /* Hides the text that overflows the cell */
  text-overflow: ellipsis;
}


 #gnom-table tr:hover { 
    background-color: #dce7f5; 
 } 


/* Popup Background Overlay */
    .popup-overlay {
      display: none; 
      position: fixed; 
      top: 0; 
      left: 0; 
      width: 100%; 
      height: 100%; 
      background-color: rgba(0, 0, 0, 0.3); 
      z-index: 1000;
    }

    /* Popup Content Box */
    .popup-content {
      position: absolute;
      top: 50%;
      left: 40%;
      transform: translate(-50%, -50%);
      background-color: #fff;
      padding: 20px;
      border-radius: 5px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.3);
      min-width: 300px;
      
      /* text-align:center; */
    }
    .popup-content a{
      display:flex;
      text-align:center;
      margin: 10px 0;
      font-size:15px;
    }
    
    .dd-image{
      cursor:pointer;
    }
    .dd-head{
       font-size:18px;
       font-weight:bold;
    }
#loader {
    background: url('/images/loading.gif') no-repeat center center;
    position: absolute;
    background-size: 100px 100px;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    z-index: 9999999;
}
</style>
<link rel="stylesheet" type="text/css" href="/css/genome_pages.css" >

<%- include('../../partials/header_html'); %>
<% ginfo = JSON.parse(data) %>
<% fltr = JSON.parse(filter) %>
<% phyla = JSON.parse(phyla) %>
<% pgdata = JSON.parse(pd) %>
<% filtergid = fltr.gid %>
<% var cfg = JSON.parse(config) %> 
<% no_ncbi_annotation = JSON.parse(no_ncbi_annot) %>




<body>
 <div id="loader" class="center-loader" style='z-index:1'></div>

  <div id='wrapper'>
    <%- include('../../partials/header_img'); %>
    <%- include('../../partials/navbar'); %>
  <div  class='page-content' >
  <p class='h3 title'><%= pgtitle %></p>

<span><small>There are <%= gcount %> genomes representing <%= tcount %> taxa (Including 'Reference' and 'Dropped' Taxa).</small></span>


<div class='download_browser_text_excel'><b>Download this Genome Data</b>: 
       <a href='/download/dld_genome_table/browser' >[Browser]</a>
       <a href='/download/dld_genome_table/text' >[Text]</a>
       <a href='/download/dld_genome_table/excel' >[Excel]</a>
       <b>OR</b> <a href='/download/download/genome'>Batch Genomic Data</a>
</div> 

 <%- include("../../partials/genome_table_basic_filter.ejs") %> 


<br><%- count_txt %>
<% if(cfg.ENV === "localhost"){ %>
<br><span style=''><small><b>Localhost ONLY</b>
  Available V11.0-PROKKA Annos: GCA_000174175.1, GCA_016648925.1, GCA_030450175.1, GCA_900105505.1, GCA_938028245.1 
  <br>Phage: GCA_000008065.1, GCA_000007645.1, GCA_000008345.1

</small></span>
<% } %>

  
<div id='genome-box'>
    <table id='gnom-table' class='table table-hover table-condensed' >
    <thead>
    <tr><th class='col0' >row #</th>
    <th class='col1' scope='col' >Genome-ID</th>
    <th class='col2' scope='col' nowrap>Taxon-ID</th>
    <th class='col3'  >Species</th>
    <th class='col4'  >Strain</th>
    <th class='col5' scope='col' >MAG</th>
    <th class='col6' title='Assembly Level' scope='col' >Assembly<br>Level</th>
    <th class='col7' scope='col' ><small>Contigs</small></th>
    <th class='col8' scope='col' >Combined<br>Length</th>
    <th class='col9' scope='col' >GC(%)</th>
    
    </tr>
    </thead>
    <tbody>
    <% if(ginfo.length === 0){ %>
       <tr><td></td><td>None Found</td></tr>
    <% }else{ %>
    
    
    <% rowcount = pgdata.start_count %>
    
    <% for(n in ginfo){ %>
      
      <% taxidfullname = "HMT-"+("0000" + ginfo[n].otid).slice(-4); %>
      <% rowid =  ginfo[n].gid.split('.')[0]; %>
      <tr id='<%= rowid %>' >
         <% if(filter_on == "off"){  %>
            <td class='right'><%= rowcount %></td>
        <% }else{ %>
            <td class='right'><%= parseInt(n) + 1 %></td>
      <% } %>
        
        <td class='linkout center' nowrap><a href="genome_description?gid=<%= ginfo[n].gid %>"> <%= ginfo[n].gid %></a>
        &nbsp;&nbsp;<img title='more...' id='<%= ginfo[n].gid %>-image' class='dd-image' src="/images/drop-down-menu-comments-icon2.png" width='23' height='18' alt="dropmenu-icon" 
         onclick="openPopup('<%= ginfo[n].gid %>', '<%= ginfo[n].otid %>', '<%= ginfo[n].gc %>','<%= ginfo[n].phage %>')" ">
        </td>
        <td class='linkout center' nowrap ><a href='/taxa/tax_description?gid=<%= ginfo[n].gid %>&otid=<%= ginfo[n].otid %>'><%= taxidfullname %></a>
        
        </td>
        <td class='tax_name ellipsis' nowrap title='<%= ginfo[n].organism %>'><a href='/taxa/life?rank=genus&name=<%= ginfo[n].genus %>&gid=<%= ginfo[n].gid %>'><em><%= ginfo[n].species %> <%= ginfo[n].subspecies %></em></a></td>
        
        <td class='tax_name ellipsis' title='<%= ginfo[n].strain %>'><em><%= ginfo[n].strain %></em></td>
        <td class='center'><%= ginfo[n].mag %></td>
        <td class='ellipsis'><%= ginfo[n].level %></td>
        <td class='center'><%= ginfo[n].contigs %></td>
        <td class='center' title='Size: <%= ginfo[n].combined_size %>bp'><%= ginfo[n].combined_size %></td>
    
        <td class='center'><%= ginfo[n].gc %></td>
        
        
        
      </tr>
      <% rowcount = rowcount + 1 %>
    <% } %>

    </tbody>
    <% } %>
    </table>
    
<!-- Popup Structure -->
  <div id="popupOverlay" class="popup-overlay" onclick="closePopup(event)">
    <div class="popup-content" onclick="event.stopPropagation()">
      <p id="popupBody" style='text-align:center;'></p>
    </div>
  </div>
  
</div>  <!-- end genome-box -->
    
  
    </div> <!-- end: page-content -->
    
    <div id='footer'>
         <%- include('../../partials/footer'); %>
    </div>
       
   
  </div> <!-- end wrapper -->
<div class="form-popup" id="myAdvancedForm">
  <%- include("../../partials/genome_table_advanced_filter.ejs") %>
  <!-- include("../../partials/tax_table_advanced_filter.ejs") -->
  <!-- include("../partials/tax_table_TEST_filter.ejs") -->
</div>
</body>

</html>

