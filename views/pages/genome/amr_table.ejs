<% var cfg = JSON.parse(config) %> 
<style>
/* Fix the tax table header */
thead th { position: sticky; top: 0; }
#amr-table.sortable tbody {
    counter-reset: sortabletablescope;
}
#amr-table.sortable thead tr::before {
    content: "";
    display: table-cell;
    width:30px;
    /* padding-left:1px; */
    vertical-align: middle;
    color:white;
    /* background:  var(--table-header-bg); */
    padding:5px;
    font-size:13px;
    text-align: center;
}
#amr-table.sortable tbody tr::before {
    content: counter(sortabletablescope);
    counter-increment: sortabletablescope;
    display: table-cell;
    text-align:right;
    font-size:small;
}
 #amr-table
{
  padding:5px;
 /*  width:1200px; */
  table-layout:fixed;
  /* table-layout:auto */
  width:100%;
  /* background:lightgrey; */
}
#amr-table th
{
  color:white;
  background:  var(--table-header-bg);
  padding:5px;
  font-size:13px;
  text-align: center;
  z-index: .5;
}
#amr-table td
{
  padding:3px 2px 2px 5px;
  
  font-size:small;
  font-weight:bold;
  color: #303030;

  white-space: nowrap;
}
#amr-table .ellipsis{
  overflow: hidden;
  text-overflow: ellipsis;
}
#amr-table tr:nth-child(even) { 
    /* background-color: var(--table-row-even1); */
 } 
 
 #amr-table tr:hover { 
    background-color: #dce7f5; 
 } 


.w-med{
    width:140px;
    text-align:center;
}
.w-vsm{
    width:60px;
    text-align:center;
}
.w-sm{
    width:90px;
    text-align:center;
}
.w-exp{
    min-width:150px;
    text-align:left;
}
#amr-sub-table-div{
    height:500px;
    overflow:auto;
}

#sub-table-div{
   display: none;
  position: fixed;
  background:lightyellow;
  width:1200px;
  padding:8px;
  margin:0px;
  border:2px solid black;
  z-index: 1;
  /* left:-160px; */
  top:350px;
}
.project_decription{
    border:1px solid black;
    background:lightgrey;
    text-align:left;
    font-size:16px;
    padding:5px;
    height:130px;
    overflow:auto;
}
#loader {
    background: url('/images/loading.gif') no-repeat center center;
    position: absolute;
    background-size: 100px 100px;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    z-index: 9999999;
}
.search-box{
   border:1px solid black;
   padding:3px 6px;
}
</style>
<% var datarows = JSON.parse(data) %>
<% var genomelist = JSON.parse(gid_list) %>

<%- include('../../partials/header_html'); %>




<body>
  <div id="loader" class="center-loader" style='z-index:1'></div>
  <div id='wrapper'>
    <%- include('../../partials/header_img'); %>
    <%- include('../../partials/navbar'); %>
    <div class='page-content' >
      
         <p class='title h3'>Anti-Microbial Resistance (AMR) detected in HOMD genomes</p>
    <br>
    <center>
    <div class='project_decription'>
        <b>Description</b>
        <br>
        Please help write me!
    </div>
    </center>
    
    
    <div class='container'>  <!-- Bootstrap container-->
    <div class="row">
    <div class="col">
        <% if(parseInt(row_count) == parseInt(tcount)){ %>
           Row Count: <b><%- tcount %></b>
        <% }else{ %>
            Available Full Count: <b><%- tcount %></b>
           <br>Showing: <b><%- row_count %></b>
        <% } %>
    </div>
    <div class="col-5 search-box">
      <form id='amr-search-form' method='post' action='amr_table'>
      Search Names:
      <input id='search_input' name='search_input' style='border:1px solid gray;padding:5px;' type='text' maxlength='50' value='<%= search %>' placeholder="Enter search term..."\>
      <button class='button' type='submit' value='Go'>Go</button>
      &nbsp;&nbsp;&nbsp;&nbsp;<small><a href='amr_table'>Reload Page</a></small>
      </form>
    </div>
    
    </div>
    </div>
       
       

<div id='amr-box' >

    
         <table id='amr-table' class='table table-hover table-condensed sortable' >
         <thead>
          <tr>
           <th class='center col1'>Genome-ID</th>
            <th class='center col1'>Taxon-ID</th>
            <th class='col3'>Species</th>
            <th class='col3'>Strain</th>
            <th class='center col1'>Contigs</th>
            <th class='center'>Length<br>(bp)</th>
            <th class='center'>Hit<br>Count</th>
            <th class='center col1 sorttable_nosort'>FTP<br>Download</th>
          </tr>
         </thead>
         <tbody>
         <% for (n in genomelist){ %>
             <% gid = genomelist[n].gid %>
             
             <% taxidfullname = "HMT-"+("0000" + datarows[gid].otid).slice(-4); %>
             <tr>
             <td class='w-med'><a href='/genome/genome_description?gid=<%= gid %>'><%= gid %></a></td>
             
             <td class='w-sm'><a href='/taxa/tax_description?gid=<%= gid %>&otid=<%= datarows[gid].otid %>'><%= taxidfullname %></a></td>
             
             <td class='w-exp ellipsis' title='<%= datarows[gid].organism %>'><i><%= datarows[gid].organism %></i></td>
             <td class='w-exp ellipsis' title='<%= datarows[gid].strain %>'><%= datarows[gid].strain %></td>
             <td class='w-vsm'><%= datarows[gid].contigs %></td>
             <td class='w-sm'><%= datarows[gid].length %></td>
             
             
             <td class='w-sm' sorttable_customkey="<%= datarows[gid].hit_count %>">
               <a href='#' onclick="get_ajax('<%= gid %>')"><%= datarows[gid].hit_count %> rows</a>
             </td>
             <td class='center'>
             <a href="<%= cfg.HOMD_URL_BASE %><%= cfg.AMR_PATH %><%= gid %>.amrfinder" target='_blank'>ftp
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-up-right-square" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M15 2a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1zM0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm5.854 8.803a.5.5 0 1 1-.708-.707L9.243 6H6.475a.5.5 0 1 1 0-1h3.975a.5.5 0 0 1 .5.5v3.975a.5.5 0 1 1-1 0V6.707z"/>
              </svg>
             </a>
             </td>
            
             </tr>
         <% } %>
         </tbody>
         </table>
         
</div>  <!-- end: amr-box -->
      <div id='sub-table-div'>XXXX</div>
    </div> <!-- end: page-content -->
    <div id='footer'>
         <%- include('../../partials/footer'); %>
    </div>
       
   
  </div> <!-- end wrapper -->
</body>

</html>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
<script type="text/javascript" src="/js/genomes.js"></script>
<script type="text/javascript" src="/js/sorttable.js"></script> <!-- https://www.kryogenix.org/code/browser/sorttable -->
<script type="text/javascript" src="/js/menu.js"></script>

<script>
  mainmenu()
  var jb_path = '<%- cfg.JBROWSE_URL %>'
  
  
  
  function get_ajax(gid){
      let args = {}
      args.gid = gid
      var xmlhttp = new XMLHttpRequest();
      xmlhttp.open("POST", "/genome/amr_ajax", true);
      xmlhttp.setRequestHeader("Content-type","application/json");
      xmlhttp.onreadystatechange = function() {
          if (xmlhttp.readyState == 4 && xmlhttp.status == 200) {
            var resp = xmlhttp.responseText;
            //console.log(resp)
            //window.open(url)
            disp = document.getElementById('sub-table-div')
            disp.innerHTML = resp
            disp.style.display = 'block'
            
          }
      }
      xmlhttp.send(JSON.stringify(args));
  }
  function close_sub_table(){
        disp = document.getElementById('sub-table-div')
        disp.style.display = 'none'
  }
  document.onreadystatechange = function() {
        // just three els to loader: this(js);css;html
        if (document.readyState !== "complete") {
            document.querySelector(
                '#amr-box').style.display = "none";
            document.querySelector(
                "#loader").style.visibility = "visible";
            
        } else {
            document.querySelector(
                '#amr-box').style.display = "block";
            document.querySelector(
                "#loader").style.visibility = "hidden";
            
                
        }
  };
</script>



